APP_NAME=Deadside Data API
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
# Railway injeta PORT automaticamente.
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With,X-Request-ID,X-CSRF-Token,X-Client-Version,X-Server-ID
CORS_EXPOSE_HEADERS=X-Request-ID,Content-Disposition,X-Total-Count
CORS_MAX_AGE_SECONDS=600
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
WEBSOCKET_ALLOW_MISSING_ORIGIN=false
TRUSTED_HOSTS=localhost,127.0.0.1,healthcheck.railway.app
FORCE_HTTPS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
DATABASE_URL=postgresql+asyncpg://deadside:deadside@db:5432/deadside
SQL_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_COMMAND_TIMEOUT_SECONDS=30
MAP_MIN_X=0
MAP_MAX_X=1280
MAP_MIN_Y=-1408
MAP_MAX_Y=0
MAP_ORIGIN_X=640
MAP_ORIGIN_Y=-192
UNREAL_UNITS_PER_MAP_UNIT=781.25
POSITION_TOLERANCE_UNREAL=1.0
FTP_PROTOCOL=ftp
FTP_HOST=127.0.0.1
FTP_PORT=21
FTP_USERNAME=change-me
FTP_PASSWORD=change-me
FTP_USE_TLS=false
FTP_PASSIVE_MODE=true
FTP_CONNECTION_TIMEOUT_SECONDS=20
FTP_OPERATION_TIMEOUT_SECONDS=30
FTP_POLL_INTERVAL_SECONDS=5
FTP_LIVE_POSITION_INTERVAL_SECONDS=0.5
FTP_SYNC_AUTOSTART=true
FTP_MAX_RETRIES=5
FTP_RETRY_BASE_SECONDS=2
FTP_DISCOVERY_MAX_DEPTH=8
FTP_ROOT_PATH=/
FTP_MAX_CONCURRENT_DOWNLOADS=2
FTP_MAX_FILES_PER_CYCLE=500
FTP_MAX_FILE_SIZE_MB=100
FTP_STABILITY_DELAY_SECONDS=0.75
KILLS_LEADERBOARD_MIN_KILLS_FOR_KD=3
WEBSOCKET_ENABLED=true
WEBSOCKET_HEARTBEAT_INTERVAL_SECONDS=25
WEBSOCKET_HEARTBEAT_TIMEOUT_SECONDS=60
WEBSOCKET_SEND_TIMEOUT_SECONDS=5
WEBSOCKET_MAX_CONNECTIONS_PER_SERVER=500
WEBSOCKET_MAX_CONNECTIONS_PER_USER=10
WEBSOCKET_MAX_MESSAGE_BYTES=65536
WEBSOCKET_EVENT_RETENTION_HOURS=24
WEBSOCKET_PERSIST_EVENTS=true
# Defina um valor forte somente no .env real; deixe vazio no exemplo.
WEBSOCKET_JWT_SECRET=
